ENVIRONMENT=development
# AWS RDS production example: append ?sslmode=verify-full&sslrootcert=/etc/ssl/certs/aws-rds-global-bundle.pem
DATABASE_URL=postgresql+psycopg://medivault:medivault@postgres:5432/medivault
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
UPLOAD_DIR=/app/uploads/medical_documents
# Use local for development. In AWS production, set s3 and provide a private bucket.
STORAGE_BACKEND=local
# S3_DOCUMENTS_BUCKET=replace-with-private-document-bucket
# S3_DOCUMENTS_PREFIX=medical-documents
# AWS_REGION=ap-south-1
COOKIE_SECURE=false
# Enable only for local demonstrations. Always use false in production.
SEED_DEMO_DATA=false
LOG_LEVEL=INFO
# Use console locally and json in staging/production.
LOG_FORMAT=console
# Set to * only when the application port is private and all traffic comes through a trusted reverse proxy.
FORWARDED_ALLOW_IPS=127.0.0.1
# Email is optional locally. For AWS SES, use the SMTP endpoint for your AWS region.
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=replace-with-ses-smtp-username
# SMTP_PASSWORD=replace-with-ses-smtp-password
# SMTP_FROM=noreply@your-verified-domain.com
# SMTP_TLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SECONDS=10
